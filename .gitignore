# --- Environment / secrets ---
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# --- Docker ---
docker-compose.override.yml
.docker/
volumes/
**/volumes/

# --- Splunk ---
splunk-config/**/etc/
splunk-config/**/var/
*.stash_new
*.splunk_bak

# Runtime state the forwarder's own provisioning writes into the
# bind-mounted splunk-config/ dir on every boot - not authored config.
# server.conf in particular holds a generated pass4SymmKey secret.
splunk-config/migration.conf
splunk-config/server.conf
splunk-config/web.conf

# Runtime state Splunk writes inside bind-mounted apps (UI edits,
# scheduler state). Authored config lives in default/, which is tracked.
splunk-apps/*/local/
splunk-apps/*/metadata/local.meta

# --- Logs ---
*.log
logs/
**/logs/

# --- Jenkins ---
jenkins/jenkins_home/
jenkins_home/
*.jenkins_bak

# --- Node (sample app) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
dist/
.npm/

# --- Java / Spring Boot (sample app) ---
target/
*.jar
*.class
!.mvn/wrapper/maven-wrapper.jar
.gradle/
build/

# --- OS / editor ---
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# Final report stays local to the EC2 instance - not committed
docs/final_report.md
